# SOLA Frontend environment example.
# Copy to .env.local and fill with real values for local development.
# Never commit real .env files. Real backend URL is required for runtime work
# (CP1 will perform the runtime handshake against this URL).

# Backend base URL. The frontend Auth Gateway and feature proxy will call this.
# Example local default for the SOLA FastAPI backend:
SOLA_BACKEND_URL=http://localhost:8000

# Public app URL exposed to the browser (used for absolute links/canonicals).
NEXT_PUBLIC_SOLA_APP_URL=http://localhost:3000
